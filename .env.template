# ReVampCI Environment Configuration Template

# Server Configuration (FastAPI)
HOST=0.0.0.0
PORT=8000

# LLM Configurations
# Gemini API Key (Required for Gemini-3.5-flash & Gemini-3.1-flash-lite)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Configuration
# GitHub Personal Access Token (Required for Git operations and creating PRs)
CUSTOM_GITHUB_TOKEN=your_github_token_here

# Database Configuration
# SQLite Database URL
DATABASE_URL=sqlite:///revampci.db

# Logging
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
